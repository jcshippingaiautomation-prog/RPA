{
  "name": "rpa-worker",
  "version": "1.0.0",
  "description": "RPA worker — polls Supabase job_queue and runs DCTK import (Playwright) on a VM",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/worker.js",
    "dev": "tsx src/worker.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "rpa-import-node": "file:../rpa-import-node"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
